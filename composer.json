{
    "name": "strawberry/sdk",
    "description": "PHP SDK for Strawberry analytics, error tracking, logs, and LLM observability. Stdlib only, zero dependencies.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/steventruong/strawberry-php",
    "version": "1.0.0",
    "keywords": ["analytics", "errors", "logs", "llm", "observability"],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Strawberry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Strawberry\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
